---

import ButtonGroup from '@components/homepage/ButtonGroup.astro';
import Features from '@components/homepage/Features.astro';
import SponsorSegment from '@components/homepage/SponsorSegment.astro';

const supportedChecks = [
  'Historique d\'archives',
  'Vérification des listes noires',
  'Empreinte carbone',
  'Cookies',
  'Serveur DNS',
  'Enregistrements DNS',
  'DNSSEC',
  'Fonctionnalités du site',
  'Types de pare-feu',
  'Obtenir l\'adresse IP',
  'En-têtes HTTP',
  'HSTS',
  'Sécurité HTTP',
  'Pages liées',
  'Configuration e-mail',
  'Ports ouverts',
  'Contrôle de qualité',
  'Rang mondial',
  'Redirection',
  'Robots.txt',
  'Capture d\'écran',
  'Security.txt',
  'Plan du site (Sitemap)',
  'Balises sociales',
  'Certificat SSL',
  'Statut de disponibilité',
  'Technologies utilisées',
  'Menaces connues',
  'Version TLS',
  'Trace Route',
  'Enregistrements TXT',
  'Recherche Whois'
];

const links = [
  {
    title: 'Voir sur GitHub',
    url: 'https://github.com/lissy93/web-check',
    icon: 'github',
    isCta: true,
  },
  {
    title: 'Déployer la vôtre',
    url: '/self-hosted-setup',
    icon: 'rocket',
    isCta: false,
  },
  {
    title: 'Utiliser l\'API',
    url: '/web-check-api',
    icon: 'code',
    isCta: false,
  },
];

---

<div class="about-section">
  <div class="features-wrap">
    <h4>Prêt à commencer ?</h4>
    <p class="what">
      Avec plus de <span>30 vérifications supportées</span>
      vous pouvez visualiser et analyser en un instant les informations clés d'un site web
    </p>
  </div>
  <hr />
  <Features supportedChecks={supportedChecks} />
  <ButtonGroup links={links} />
  <hr />
  <SponsorSegment />
</div>

<style lang="scss">
  .about-section {
    width: 85vw;
    max-width: 1200px;
    margin: 4rem auto 2rem auto;
  }
  .features-wrap {
    max-width: 650px;
    margin: 0 auto 2rem auto;
  }
  h4 {
    font-size: 2rem;
    font-weight: 700;
    text-align: center;
    color: #f8fafc;
    letter-spacing: -0.02em;
  }
  .what {
    text-align: center;
    font-size: 1.15rem;
    line-height: 1.6;
    color: var(--text-color-secondary);
    margin-top: 0.5rem;
    span {
      color: #60a5fa;
      font-weight: 600;
      font-style: normal;
    }
  }
  hr {
    width: 100%;
    max-width: 200px;
    height: 1px;
    border: none;
    background: linear-gradient(90deg, transparent, rgba(59, 130, 246, 0.3), transparent);
    margin: 3rem auto;
  }
</style>
