---
import AnimatedButton from "./AnimatedButton.astro"
import AnimatedInput from "./AnimatedInput.astro"
import Screenshots from "./Screenshots.astro"
---

<div class="hero">
<div class="left">
  <div class="badge">
    <span class="badge-dot"></span>
    Outil OSINT & Sécurité Web
  </div>
  <h1>
    <img src="/favicon.svg" alt="Check Web" width="64" />
    <span class="web">Web</span>
    <span class="check">Check</span>
  </h1>
  <div class="homepage-action-content">
    <h2>Vision Rayons X<br />pour votre site Web</h2>
    <h3>
      En seulement 20 secondes, découvrez
      <span>ce que les attaquants savent déjà</span>
    </h3>
    <form name="live-start" autocomplete="off" action="/check" class="live-start" id="live-start">
      <label for="url">Entrez une URL à analyser</label>
      <AnimatedInput />
      <AnimatedButton />
    </form>
  </div>
</div>
<Screenshots />
</div>

<script>
  const form = document.getElementById('live-start');
  const urlInput = document.getElementById('url-input') as HTMLInputElement;
    
  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    const url = urlInput.value.trim();
    if (url) {
      const encodedUrl = encodeURIComponent(url);
      window.location.href = `/check/${encodedUrl}`;
    }
  });
  
  urlInput?.addEventListener('keydown', (event) => {
    if (event.key === 'Enter') {
      const url = urlInput.value.trim();
      const urlWithoutProtocolRegex = /^[a-zA-Z0-9]+[a-zA-Z0-9.-]*\.[a-zA-Z]{2,}$/;
      if (url && !/^https?:\/\//i.test(url) && urlWithoutProtocolRegex.test(url)) {
        urlInput.value = 'https://' + url;
        form?.dispatchEvent(new Event('submit'));
      }
    }
  });
  </script>

<style lang="scss">
@import '@styles/global.scss';
.hero {
  display: flex;
  justify-content: space-around;
  width: 100vw;
  max-width: 1400px;
  margin: 0 auto;
  padding-top: 2rem;
  @include desktop-down {
    display: block;
    width: 85vw;
    margin: 0 auto;
  }
}
.left {
    min-height: 80vh;
    display: flex;
    flex-direction: column;
    gap: 3rem;
    @include tablet-landscape-down {
      gap: 2.5rem;
    }
    .badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      width: fit-content;
      padding: 0.4rem 0.9rem;
      border-radius: 9999px;
      background: rgba(59, 130, 246, 0.1);
      border: 1px solid rgba(59, 130, 246, 0.25);
      color: #60a5fa;
      font-size: 0.85rem;
      font-weight: 500;
      .badge-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #3b82f6;
        box-shadow: 0 0 8px #3b82f6;
      }
    }
    h1 {
      margin: 0;
      font-size: 2.5rem;
      z-index: 5;
      display: flex;
      gap: 0.25rem;
      align-items: center;
      img {
        vertical-align: middle;
        width: 2.5rem;
        margin-right: 0.5rem;
      }
      .web {
        color: #f8fafc;
        font-weight: 800;
      }
      .check {
        color: var(--primary);
        font-weight: 800;
        font-style: normal;
      }
    }
    .homepage-action-content {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
      max-width: 650px;
      z-index: 1;
      h2 {
        font-size: 3.25rem;
        font-weight: 800;
        line-height: 1.15;
        letter-spacing: -0.03em;
        background: linear-gradient(135deg, #ffffff 0%, #cbd5e1 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      h3 {
        font-weight: 400;
        font-size: 1.2rem;
        color: var(--text-color-secondary);
        line-height: 1.5;
        span {
          color: #60a5fa;
          font-weight: 500;
        }
      }
      form {
        margin-top: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        label {
          font-size: 1rem;
          font-weight: 600;
          color: #f8fafc;
        }
      }
    }
  }
</style>
