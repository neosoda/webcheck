---
const repo = 'github.com/lissy93/web-check';
const github = `https://${repo}`;

const licenseText = 'MIT';
const licenseLink = `${github}/blob/master/LICENSE`;

const aboutLink = '/about';
const projectName = 'Web Check';

const authorName = 'Alicia Sykes';
const authorLink = 'https://aliciasykes.com';
const currentYear = new Date().getFullYear();
---

<footer>
  <p>
    Voir le code source sur <a href={github}>{repo}</a>
  </p>
  <p>
    <a href={aboutLink}>{projectName}</a>
    est sous licence
    <a href={licenseLink}>{licenseText}</a>
    - © <a href={authorLink}>{authorName}</a>
    {currentYear}
  </p>
</footer>

<style lang="scss">
  @import '@styles/global.scss';
  footer {
    margin-top: 3rem;
    background: rgba(17, 24, 39, 0.6);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--text-color-secondary);
    padding: 1.5rem 2rem;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    backdrop-filter: blur(10px);
    p {
      margin: 0;
      color: var(--text-color-secondary);
      font-size: 0.9rem;
    }
    a {
      color: var(--primary-lighter);
      text-decoration: none;
      &:hover {
        text-decoration: underline;
      }
    }
    @include tablet-portrait-down {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
  }
</style>
